{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VideoEditHelper",
  "version": "0.1.0",
  "identifier": "io.github.tainakanchu.video-edit-helper",
  "build": {
    "frontendDist": "splash",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run tauri:prepare"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Video Edit Helper",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/veh-server"],
    "resources": {
      "resources/whisper": "whisper",
      "../packages/web/dist": "web-dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
